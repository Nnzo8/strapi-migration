{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "key": {
      "type": "string",
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "projectStatus": {
      "type": "enumeration",
      "enum": [
        "Live",
        "Dev",
        "Revamp"
      ]
    },
    "icon": {
      "type": "string"
    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "projects"
    },
    "projectMeta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.project-meta"
    },
    "purpose": {
      "type": "text"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "shared.tool-feature"
    },
    "folderStructure": {
      "type": "component",
      "repeatable": false,
      "component": "shared.code-block"
    },
    "gettingStarted": {
      "type": "component",
      "repeatable": true,
      "component": "shared.code-step"
    },
    "contacts": {
      "type": "component",
      "repeatable": true,
      "component": "shared.contact"
    },
    "links": {
      "type": "component",
      "repeatable": true,
      "component": "shared.link"
    }
  }
}
